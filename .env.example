# Copy to .env and adjust values for local development.
# None of these are required — defaults are shown.

# Set to "true" to enable Flask debug mode (auto-reload, detailed errors)
FLASK_DEBUG=false

# Port the dev server listens on
PORT=5002

# Path to the SQLite database file
DATABASE_URL=data/fi_tracker.db

# Ollama base URL for AI report generation
OLLAMA_URL=http://localhost:11434

# Ollama model to use for report generation
OLLAMA_MODEL=minimax-m2.7:cloud
